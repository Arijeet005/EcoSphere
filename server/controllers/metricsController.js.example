import prisma from '../config/db.js';
import { getEsgScore } from '../services/mlClient.js';

export const getMetrics = async (req, res, next) => {
  try {
    const metrics = await prisma.esgMetric.findMany({
      include: { department: true, submittedBy: { select: { id: true, name: true, role: true } } },
      orderBy: { date: 'desc' },
    });

    // Example integration pattern for the ML microservice:
    // 1. Map the returned ESG metrics into the shape expected by the ML service.
    // 2. Call getEsgScore(metricsPayload).
    // 3. Attach the score to the response payload, while gracefully handling any errors.
    //
    // const payload = {
    //   environmental: metrics.find((item) => item.type === 'ENVIRONMENTAL')?.value || 0,
    //   social: metrics.find((item) => item.type === 'SOCIAL')?.value || 0,
    //   governance: metrics.find((item) => item.type === 'GOVERNANCE')?.value || 0,
    // };
    //
    // let mlScore = null;
    // try {
    //   mlScore = await getEsgScore(payload);
    // } catch (error) {
    //   mlScore = { error: error.message };
    // }
    //
    // res.json({ success: true, data: metrics, mlScore });

    res.json({ success: true, data: metrics });
  } catch (error) {
    next(error);
  }
};
