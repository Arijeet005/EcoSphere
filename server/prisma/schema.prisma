generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MANAGER
  EMPLOYEE
}

enum MetricType {
  ENVIRONMENTAL
  SOCIAL
  GOVERNANCE
}

enum ComplianceStatus {
  PENDING
  DONE
  OVERDUE
}

enum TransactionSource {
  MANUAL
}

enum ChallengeStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum ParticipationStatus {
  JOINED
  COMPLETED
}

enum EmployeeParticipationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ComplianceIssueStatus {
  OPEN
  CLOSED
}

model Department {
  id                 Int                 @id @default(autoincrement())
  name               String              @unique
  users              User[]
  metrics            EsgMetric[]
  complianceItems    ComplianceItem[]
  carbonTransactions CarbonTransaction[]
  complianceIssues   ComplianceIssue[]
  departmentScores   DepartmentScore[]
  challenges         Challenge[]
  csrActivityLogs    CSRActivity[]
  userDepartments    UserDepartment[]

  @@index([name])
}

model UserDepartment {
  id           Int        @id @default(autoincrement())
  userId       Int
  departmentId Int
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, departmentId])
  @@index([departmentId])
}

model User {
  id                        Int                      @id @default(autoincrement())
  name                      String
  email                     String                   @unique
  passwordHash              String
  role                      Role                     @default(EMPLOYEE)
  departmentId              Int?
  department                Department?              @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  metrics                   EsgMetric[]              @relation("MetricSubmittedBy")
  csrActivities             CsrActivity[]            @relation("ActivityParticipant")
  auditLogs                 AuditLog[]               @relation("AuditPerformedBy")
  createdEmissionFactors    EmissionFactor[]         @relation("EmissionFactorCreatedBy")
  createdCarbonTransactions CarbonTransaction[]      @relation("CarbonTransactionCreatedBy")
  challengeParticipations   ChallengeParticipation[]
  employeeParticipations    EmployeeParticipation[]
  ownedComplianceIssues     ComplianceIssue[]        @relation("ComplianceIssueOwner")
  createdChallenges         Challenge[]              @relation("ChallengeCreatedBy")
  departments               UserDepartment[]
  points                    Int                      @default(0)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt

  @@index([departmentId])
}

model EsgMetric {
  id            Int        @id @default(autoincrement())
  type          MetricType
  name          String
  value         Float
  unit          String
  departmentId  Int
  department    Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  submittedById Int
  submittedBy   User       @relation("MetricSubmittedBy", fields: [submittedById], references: [id], onDelete: Cascade)
  date          DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([departmentId])
  @@index([date])
}

model ComplianceItem {
  id           Int              @id @default(autoincrement())
  title        String
  framework    String
  dueDate      DateTime
  status       ComplianceStatus @default(PENDING)
  departmentId Int
  department   Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([departmentId])
  @@index([dueDate])
}

model CsrActivity {
  id            Int      @id @default(autoincrement())
  title         String
  description   String
  participantId Int
  participant   User     @relation("ActivityParticipant", fields: [participantId], references: [id], onDelete: Cascade)
  date          DateTime @default(now())
  hoursSpent    Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([participantId])
  @@index([date])
}

model AuditLog {
  id            Int      @id @default(autoincrement())
  action        String
  entity        String
  entityId      Int
  performedById Int?
  performedBy   User?    @relation("AuditPerformedBy", fields: [performedById], references: [id], onDelete: SetNull)
  oldValue      Json?
  newValue      Json?
  timestamp     DateTime @default(now())

  @@index([entity, entityId])
  @@index([timestamp])
}

model EmissionFactor {
  id                 Int                 @id @default(autoincrement())
  name               String
  category           String
  categoryId         Int?
  categoryRef        Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  unit               String
  co2PerUnit         Float
  createdById        Int?
  createdBy          User?               @relation("EmissionFactorCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  carbonTransactions CarbonTransaction[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([category])
  @@index([categoryId])
  @@index([name])
}

model CarbonTransaction {
  id                 Int               @id @default(autoincrement())
  departmentId       Int
  department         Department        @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  emissionFactorId   Int
  emissionFactor     EmissionFactor    @relation(fields: [emissionFactorId], references: [id], onDelete: Restrict)
  quantity           Float
  calculatedEmission Float
  source             TransactionSource @default(MANUAL)
  createdById        Int
  createdBy          User              @relation("CarbonTransactionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  date               DateTime          @default(now())
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([departmentId])
  @@index([date])
  @@index([emissionFactorId])
}

model Category {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  description     String?
  emissionFactors EmissionFactor[]
  badges          Badge[]
  rewards         Reward[]
  challenges      Challenge[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([name])
}

model Badge {
  id                     Int                     @id @default(autoincrement())
  name                   String
  description            String?
  categoryId             Int?
  category               Category?               @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  employeeParticipations EmployeeParticipation[] @relation("BadgeAwardedTo")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@unique([name, categoryId])
  @@index([categoryId])
}

model Reward {
  id                     Int                     @id @default(autoincrement())
  name                   String
  description            String?
  categoryId             Int?
  pointsCost             Int                     @default(0)
  category               Category?               @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  employeeParticipations EmployeeParticipation[] @relation("RewardRedeemedBy")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@unique([name, categoryId])
  @@index([categoryId])
}

model CSRActivity {
  id                     Int                     @id @default(autoincrement())
  title                  String
  description            String?
  departmentId           Int?
  department             Department?             @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  activityDate           DateTime                @default(now())
  hoursSpent             Float                   @default(0)
  evidenceRequired       Boolean                 @default(false)
  pointsValue            Int                     @default(0)
  employeeParticipations EmployeeParticipation[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([departmentId])
  @@index([activityDate])
}

model EmployeeParticipation {
  id             Int                         @id @default(autoincrement())
  userId         Int
  csrActivityId  Int?
  badgeId        Int?
  rewardId       Int?
  pointsEarned   Int                         @default(0)
  proofUrl       String?
  status         EmployeeParticipationStatus @default(PENDING)
  participatedAt DateTime                    @default(now())
  user           User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  csrActivity    CSRActivity?                @relation(fields: [csrActivityId], references: [id], onDelete: SetNull)
  badgeAwarded   Badge?                      @relation("BadgeAwardedTo", fields: [badgeId], references: [id], onDelete: SetNull)
  rewardRedeemed Reward?                     @relation("RewardRedeemedBy", fields: [rewardId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([csrActivityId])
  @@index([status])
  @@index([participatedAt])
}

model Challenge {
  id                      Int                      @id @default(autoincrement())
  title                   String
  description             String?
  departmentId            Int?
  categoryId              Int?
  createdById             Int?
  startDate               DateTime
  endDate                 DateTime
  status                  ChallengeStatus          @default(DRAFT)
  department              Department?              @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  category                Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy               User?                    @relation("ChallengeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  challengeParticipations ChallengeParticipation[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  @@index([departmentId])
  @@index([categoryId])
  @@index([status])
}

model ChallengeParticipation {
  id            Int                 @id @default(autoincrement())
  challengeId   Int
  userId        Int
  status        ParticipationStatus @default(JOINED)
  progressValue Float?              @default(0)
  joinedAt      DateTime            @default(now())
  completedAt   DateTime?
  challenge     Challenge           @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([userId])
  @@index([status])
}

model ComplianceIssue {
  id           Int                   @id @default(autoincrement())
  departmentId Int
  ownerId      Int
  title        String
  description  String?
  severity     IssueSeverity         @default(MEDIUM)
  status       ComplianceIssueStatus @default(OPEN)
  dueDate      DateTime
  isResolved   Boolean               @default(false)
  raisedAt     DateTime              @default(now())
  resolvedAt   DateTime?
  department   Department            @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  owner        User                  @relation("ComplianceIssueOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  @@index([departmentId])
  @@index([ownerId])
  @@index([severity])
  @@index([status])
  @@index([dueDate])
  @@index([isResolved])
}

model DepartmentScore {
  id            Int        @id @default(autoincrement())
  departmentId  Int
  scoreDate     DateTime   @default(now())
  environmental Float      @default(0)
  social        Float      @default(0)
  governance    Float      @default(0)
  totalScore    Float      @default(0)
  department    Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([departmentId, scoreDate])
  @@index([departmentId])
  @@index([scoreDate])
}
